// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["retencao", "shared"]
}

enum Role {
  ADMIN
  ATENDENTE

  @@schema("retencao")
}

enum StatusRetencao {
  CANCELADO
  RETIDO
  INADIMPLENCIA

  @@schema("retencao")
}

enum Regiao {
  SINOS
  LITORAL
  MATRIZ

  @@schema("retencao")
}

enum MotivoCancelamento {
  INSATISFACAO_ATD
  INSATISFACAO_SERVICO
  MUDANCA_ENDERECO
  MOTIVOS_PESSOAIS
  TROCA_PROVEDOR
  PROBLEMAS_FINANC
  OUTROS
  INADIMPLENCIA_90  // usado automaticamente quando status = INADIMPLENCIA

  @@schema("retencao")
}

// Cidade agora é uma tabela editável (antes era enum)
model Cidade {
  id        String   @id          // ex: "CACHOEIRINHA" — mesmo valor do antigo enum
  nome      String                // ex: "Cachoeirinha" — nome legível
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  solicitacoes SolicitacaoRetencao[]

  @@schema("retencao")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(ATENDENTE)
  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  solicitacoes SolicitacaoRetencao[] @relation("AtendenteSolicitacoes")

  @@schema("retencao")
}

model Competencia {
  id                String   @id @default(cuid())
  ano               Int
  mes               Int

  metaCancelamentos Int?
  orcamentoComissaoCents Int?
  baseAtivosTotal   Int?
  inadimplenciaTotal Int?

  diasUteis         Int?
  diasTrabalhados   Int?
  metaDiariaManual  Int?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  solicitacoes      SolicitacaoRetencao[]

  @@unique([ano, mes])
  @@schema("retencao")
}

model SolicitacaoRetencao {
  id             String       @id @default(cuid())

  competenciaId  String
  competencia    Competencia  @relation(fields: [competenciaId], references: [id], onDelete: Cascade)

  dataRegistro   DateTime
  status         StatusRetencao

  nomeCliente    String
  bairro         String?
  contato        String?

  cidade         String
  cidadeInfo     Cidade       @relation(fields: [cidade], references: [id])

  regiao         Regiao

  agendaRetirada DateTime?
  retiradaTexto  String?

  atendenteId    String
  atendente      User         @relation("AtendenteSolicitacoes", fields: [atendenteId], references: [id])

  motivo         MotivoCancelamento?
  observacoes    String?

  registradoIXC  Boolean      @default(false)
  transbordo     String?

  // Valor mensal do plano do cliente em centavos (9990 = R$ 99,90).
  // Usado para calcular MRR cancelado / MRR retido nas métricas.
  ticketCents    Int?

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([competenciaId, status])
  @@index([competenciaId, motivo])
  @@index([atendenteId])
  @@index([cidade])
  @@index([regiao])
  @@index([customerId])
  @@schema("retencao")
}

// ========================
// SHARED — Cliente unificado
// ========================

/// Fonte da verdade do cliente, compartilhada entre CRM Comercial e CRM Retenção.
/// ESPELHADO: os campos escalares deste model devem ser IDÊNTICOS ao Customer em
/// crm-comercial-fenix/prisma/schema.prisma. As relações inversas (vendas, leads,
/// solicitacoes) são específicas de cada projeto — não precisam bater.
model Customer {
  id              String  @id @default(cuid())
  cpfCnpj         String  @unique
  nome            String
  contatoPrimario String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  solicitacoes SolicitacaoRetencao[]

  @@schema("shared")
}
